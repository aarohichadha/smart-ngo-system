{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./frontend/src/*"
      ]
    },
    "skipLibCheck": true,
    "noEmit": true,
    "strictNullChecks": false
  },
  "include": ["frontend/src", "backend/src"]
}